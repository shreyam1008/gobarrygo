        "url": "https://shreyam1008.com.np",
        "sameAs": [
          "https://github.com/shreyam1008",
          "https://shreyam1008.com.np"
        ]
      },
      "sourceOrganization": {
        "@type": "Person",
        "name": "Shreyam Adhikari",
        "url": "https://shreyam1008.com.np"
      },
      "codeRepository": repoUrl,
      "programmingLanguage": ["Go", "TypeScript", "React"],
