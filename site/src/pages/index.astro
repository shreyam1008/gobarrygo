---
const repoUrl = "https://github.com/shreyam1008/gobarrygo";
const authorUrl = "https://shreyam1008.com.np";
const siteTitle = "GoBarryGo - Ultra-light Aria2c Desktop Controller";
const siteDescription = "A super lightweight, fast, and portable desktop manager for aria2c. Native performance, minimal RAM usage, and easy installation.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={siteDescription} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://shreyam1008.github.io/gobarrygo/" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://shreyam1008.github.io/gobarrygo/" />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={siteDescription} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono&display=swap" rel="stylesheet">

    <style>
      :root {
        --bg: #030712;
        --fg: #f3f4f6;
        --accent: #3b82f6;
        --accent-glow: rgba(59, 130, 246, 0.4);
        --card-bg: #111827;
        --border: #1f2937;
        --muted: #9ca3af;
      }

      * { box-sizing: border-box; }

      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overflow-x: hidden;
      }

      .hero-gradient {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 100%;
        height: 500px;
        background: radial-gradient(circle at center, var(--accent-glow) 0%, transparent 70%);
        opacity: 0.3;
        z-index: -1;
      }

      .container {
        max-width: 900px;
        width: 100%;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      header {
        text-align: center;
        margin-bottom: 5rem;
      }

      h1 {
        font-size: clamp(3rem, 10vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.05em;
        margin: 0 0 1rem 0;
        background: linear-gradient(to bottom right, #fff 50%, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .subtitle {
        font-size: 1.5rem;
        color: var(--muted);
        max-width: 600px;
        margin: 0 auto 2.5rem;
      }

      .actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        padding: 0.875rem 1.75rem;
        border-radius: 9999px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem;
      }

      .btn-primary {
        background-color: var(--accent);
        color: #fff;
        box-shadow: 0 4px 14px 0 var(--accent-glow);
      }

      .btn-primary:hover {
        transform: translateY(-2px);
        background-color: #2563eb;
        box-shadow: 0 6px 20px 0 var(--accent-glow);
      }

      .btn-secondary {
        background-color: var(--card-bg);
        color: var(--fg);
        border: 1px solid var(--border);
      }

      .btn-secondary:hover {
        background-color: var(--border);
        transform: translateY(-2px);
      }

      section {
        margin-bottom: 6rem;
      }

      h2 {
        font-size: 2.25rem;
        font-weight: 700;
        margin-bottom: 2rem;
        text-align: center;
      }

      .install-card {
        background: linear-gradient(145deg, var(--card-bg), #0f172a);
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        padding: 3rem;
        position: relative;
        overflow: hidden;
      }

      .code-snippet {
        background: #000;
        padding: 1.25rem;
        border-radius: 0.75rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.95rem;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 2rem 0;
      }

      .code-snippet code { color: #60a5fa; }
      .code-snippet span { color: var(--muted); user-select: none; }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
      }

      .feature-card {
        background-color: var(--card-bg);
        border: 1px solid var(--border);
        padding: 2.5rem;
        border-radius: 1.25rem;
        transition: border-color 0.2s;
      }

      .feature-card:hover {
        border-color: var(--accent);
      }

      .feature-card h3 {
        font-size: 1.5rem;
        margin-top: 0;
        color: #fff;
      }

      .feature-card p {
        color: var(--muted);
        margin-bottom: 0;
      }

      footer {
        padding: 4rem 1.5rem;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--muted);
      }

      footer a {
        color: var(--fg);
        text-decoration: none;
        font-weight: 600;
      }

      footer a:hover {
        color: var(--accent);
      }

      @media (max-width: 640px) {
        h1 { font-size: 3.5rem; }
        .install-card { padding: 1.5rem; }
        .code-snippet { font-size: 0.8rem; }
      }
    </style>
  </head>
  <body>
    <div class="hero-gradient"></div>
    <div class="container">
      <header>
        <h1>GoBarryGo</h1>
        <p class="subtitle">
          The ultra-lightweight, portable Aria2c desktop controller that just works.
        </p>
        <div class="actions">
          <a href={repoUrl + "/releases"} class="btn btn-primary">Download Now</a>
          <a href={repoUrl} class="btn btn-secondary" target="_blank">Star on GitHub</a>
        </div>
      </header>

      <section>
        <div class="install-card">
          <h2 style="margin-top: 0; text-align: left;">Quick Install</h2>
          <p style="color: var(--muted); font-size: 1.125rem;">
            Run the universal installer on Linux, macOS, or Windows (Git Bash). No dependencies required.
          </p>
          <div class="code-snippet">
            <span>$</span>
            <code>curl -fsSL {repoUrl}/raw/main/install.sh | bash</code>
          </div>
          <p style="font-size: 0.875rem; color: var(--muted); margin: 0;">
            Bundled with Aria2c management and automatic path configuration.
          </p>
        </div>
      </section>

      <section>
        <h2>Why GoBarryGo?</h2>
        <div class="grid">
          <div class="feature-card">
            <h3>⚡ Performance First</h3>
            <p>Built with Go and React 19. Significant RAM savings compared to Electron-based alternatives.</p>
          </div>
          <div class="feature-card">
            <h3>📦 Zero Install</h3>
            <p>Single-binary portability. Packaged as AppImage (Linux), ZIP (macOS), and NSIS (Windows).</p>
          </div>
          <div class="feature-card">
            <h3>🎨 Modern UI</h3>
            <p>A clean, responsive dashboard to manage your downloads with ease. Native look and feel.</p>
          </div>
        </div>
      </section>
    </div>

    <footer>
      <p>
        Designed & Built by <a href={authorUrl} target="_blank">Shreyam1008 (@buggythegreat)</a>
      </p>
      <p style="font-size: 0.875rem; margin-top: 1rem;">
        &copy; 2026 GoBarryGo Project &bull; MIT License
      </p>
    </footer>
  </body>
</html>
