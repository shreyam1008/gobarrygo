---
const repoUrl = "https://github.com/shreyam1008/gobarrygo";
const dlBase = repoUrl + "/releases/download/v0.0.6";
const latestDl = repoUrl + "/releases/latest/download";
const authorUrl = "https://shreyam1008.com.np";
const siteTitle = "GoBarryGo - Ultra-light Aria2c Desktop Controller";
const siteDescription = "A blazing-fast, ultra-lightweight desktop download manager powered by aria2c. Built with Go + React 19 by Shreyam Adhikari. Under 30 MB RAM, cross-platform. Free and open source.";
const siteUrl = "https://shreyam1008.github.io/gobarrygo/";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/gobarrygo/favicon.svg" />
    <link rel="canonical" href={siteUrl} />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={siteDescription} />
    <meta name="keywords" content="download manager, aria2c, aria2, desktop app, Go, React, lightweight, open source, Linux, Windows, macOS, AppImage, deb, rpm, Wails, Shreyam Adhikari, shreyam1008" />
    <meta name="author" content="Shreyam Adhikari (shreyam1008)" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#030712" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:site_name" content="GoBarryGo" />
    <meta property="og:locale" content="en_US" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={siteUrl} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={siteDescription} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Structured Data: Software Application -->
