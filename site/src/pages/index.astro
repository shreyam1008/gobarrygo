---
const repoUrl = "https://github.com/shreyam1008/gobarrygo";
const authorUrl = "https://shreyam1008.com.np";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>GoBarryGo - Lightweight Aria2c Controller</title>
    <style>
      :root {
        --bg-color: #0d1117;
        --text-color: #c9d1d9;
        --accent-color: #58a6ff;
        --code-bg: #161b22;
        --border-color: #30363d;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        line-height: 1.6;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
      }
      .container {
        max-width: 800px;
        width: 100%;
        padding: 2rem;
        box-sizing: border-box;
      }
      header {
        text-align: center;
        margin-bottom: 3rem;
      }
      h1 {
        font-size: 3rem;
        margin-bottom: 0.5rem;
        color: #fff;
      }
      .subtitle {
        font-size: 1.25rem;
        color: #8b949e;
        margin-bottom: 2rem;
      }
      .install-card {
        background-color: var(--code-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 2rem;
        margin-bottom: 2rem;
      }
      .install-card h2 {
        margin-top: 0;
        color: #fff;
      }
      .code-block {
        background-color: #000;
        padding: 1rem;
        border-radius: 6px;
        font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
        font-size: 0.9rem;
        color: #e6edf3;
        overflow-x: auto;
        border: 1px solid var(--border-color);
      }
      .code-block::before {
        content: "$ ";
        color: #8b949e;
      }
      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-top: 3rem;
      }
      .feature {
        background-color: var(--code-bg);
        border: 1px solid var(--border-color);
        padding: 1.5rem;
        border-radius: 8px;
      }
      .feature h3 {
        color: var(--accent-color);
        margin-top: 0;
      }
      a {
        color: var(--accent-color);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      footer {
        margin-top: auto;
        padding: 2rem;
        text-align: center;
        color: #8b949e;
        font-size: 0.9rem;
      }
      .btn {
        display: inline-block;
        background-color: #238636;
        color: #fff;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid rgba(240, 246, 252, 0.1);
        transition: background-color 0.2s;
      }
      .btn:hover {
        background-color: #2ea043;
        text-decoration: none;
      }
      .btn-outline {
        background-color: transparent;
        color: var(--accent-color);
        border-color: var(--border-color);
      }
      .btn-outline:hover {
        background-color: var(--border-color);
        color: var(--accent-color);
      }
      .actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 1.5rem;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>GoBarryGo</h1>
        <div class="subtitle">A super lightweight, portable aria2c desktop controller.</div>
        <div class="actions">
          <a href={repoUrl + "/releases"} class="btn">View Releases</a>
          <a href={repoUrl} class="btn btn-outline" target="_blank">GitHub Repository</a>
        </div>
      </header>

      <div class="install-card">
        <h2>Quick Install</h2>
        <p>Install the standalone binary on Linux, macOS, or Windows Git Bash:</p>
        <div class="code-block">curl -fsSL https://raw.githubusercontent.com/shreyam1008/gobarrygo/main/install.sh | bash</div>
        <p style="margin-top: 1rem; font-size: 0.9rem; color: #8b949e;">No Go, Node.js, or complex dependencies required.</p>
      </div>

      <div class="features">
        <div class="feature">
          <h3>⚡ Super Lightweight</h3>
          <p>Built as a single compiled binary using Wails and Go. Eats almost no RAM compared to Electron alternatives.</p>
        </div>
        <div class="feature">
          <h3>📦 Highly Portable</h3>
          <p>Download a single executable and run it anywhere. No installation required on Windows.</p>
        </div>
        <div class="feature">
          <h3>🚀 Beautifully Fast</h3>
          <p>Built with React and Vite for a beautiful, responsive user interface.</p>
        </div>
      </div>
    </div>
    
    <footer>
      <p>Created by <a href={authorUrl} target="_blank">Shreyam1008 (@buggythegreat)</a></p>
      <p>MIT Licensed • Open Source Software</p>
    </footer>
  </body>
</html>
