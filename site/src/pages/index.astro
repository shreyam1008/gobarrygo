---
const repoUrl = "https://github.com/shreyam1008/gobarrygo";
const authorUrl = "https://shreyam1008.com.np";
const siteTitle = "GoBarryGo - Ultra-light Aria2c Desktop Controller";
const siteDescription = "A super lightweight, fast, and portable desktop download manager powered by aria2c. Native Go + React 19 performance, under 30 MB RAM, cross-platform.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/gobarrygo/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={siteDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://shreyam1008.github.io/gobarrygo/" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://shreyam1008.github.io/gobarrygo/" />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={siteDescription} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
      :root {
        --bg: #030712;
        --fg: #f3f4f6;
        --accent: #3b82f6;
        --accent-glow: rgba(59, 130, 246, 0.4);
        --teal: #2dd4bf;
        --teal-glow: rgba(45, 212, 191, 0.3);
        --amber: #f59e0b;
        --card-bg: #111827;
        --card-bg-hover: #1a2332;
        --border: #1f2937;
        --border-hover: #374151;
        --muted: #9ca3af;
        --radius: 1.25rem;
      }

      * { box-sizing: border-box; margin: 0; }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        overflow-x: hidden;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .hero-glow {
        position: absolute;
        top: -120px;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 600px;
        background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
        opacity: 0.25;
        pointer-events: none;
      }

      .container { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }

      /* ── Nav ── */
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        max-width: 960px;
        margin: 0 auto;
      }
      .nav-brand {
        font-weight: 800;
        font-size: 1.15rem;
        color: var(--fg);
        text-decoration: none;
        letter-spacing: -0.03em;
      }
      .nav-links { display: flex; gap: 1.5rem; align-items: center; }
      .nav-links a {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.15s;
      }
      .nav-links a:hover { color: var(--fg); text-decoration: none; }

      /* ── Hero ── */
      .hero {
        position: relative;
        text-align: center;
        padding: 6rem 1.5rem 5rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.12);
        border: 1px solid rgba(59, 130, 246, 0.2);
        color: #93c5fd;
        font-size: 0.82rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
      }

      h1 {
        font-size: clamp(2.8rem, 8vw, 4.5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.05;
        margin-bottom: 1.25rem;
        background: linear-gradient(to bottom right, #fff 40%, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .hero-sub {
        font-size: 1.2rem;
        color: var(--muted);
        max-width: 580px;
        margin: 0 auto 2.5rem;
        line-height: 1.7;
      }

      .actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.8rem 1.6rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        cursor: pointer;
      }
      .btn:hover { text-decoration: none; }

      .btn-primary {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 4px 16px var(--accent-glow);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        background: #2563eb;
        box-shadow: 0 8px 24px var(--accent-glow);
      }

      .btn-ghost {
        background: rgba(255,255,255,0.06);
        color: var(--fg);
        border: 1px solid var(--border);
      }
      .btn-ghost:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-2px);
      }

      /* ── Sections ── */
      section { padding: 5rem 0; }
      section + section { border-top: 1px solid var(--border); }

      .section-label {
        display: block;
        text-align: center;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        margin-bottom: 0.75rem;
      }

      h2 {
        font-size: 2.25rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 1rem;
        letter-spacing: -0.03em;
      }

      .section-desc {
        text-align: center;
        color: var(--muted);
        max-width: 600px;
        margin: 0 auto 3rem;
        font-size: 1.05rem;
      }

      /* ── Install ── */
      .install-card {
        background: linear-gradient(145deg, var(--card-bg), #0d1520);
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        padding: 2.5rem;
        max-width: 700px;
        margin: 0 auto;
      }

      .install-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
      }

      .tab {
        padding: 0.5rem 1rem;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 500;
        background: rgba(255,255,255,0.06);
        color: var(--muted);
        border: 1px solid transparent;
      }

      .tab--active {
        background: rgba(59, 130, 246, 0.15);
        color: #93c5fd;
        border-color: rgba(59, 130, 246, 0.25);
      }

      .code-block {
        background: #000;
        padding: 1rem 1.25rem;
        border-radius: 0.75rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.88rem;
        border: 1px solid var(--border);
        overflow-x: auto;
        margin-bottom: 1rem;
        line-height: 1.7;
      }

      .code-block .prompt { color: var(--muted); user-select: none; }
      .code-block .cmd { color: #93c5fd; }
      .code-block .comment { color: #6b7280; }

      .install-note {
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.6;
      }

      /* ── Features Grid ── */
      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }

      .card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2rem;
        transition: border-color 0.2s, background 0.2s;
      }
      .card:hover {
        border-color: var(--border-hover);
        background: var(--card-bg-hover);
      }

      .card-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        margin-bottom: 1rem;
      }

      .card-icon--blue { background: rgba(59,130,246,0.15); }
      .card-icon--teal { background: rgba(45,212,191,0.15); }
      .card-icon--amber { background: rgba(245,158,11,0.15); }
      .card-icon--rose { background: rgba(244,63,94,0.15); }
      .card-icon--violet { background: rgba(139,92,246,0.15); }
      .card-icon--green { background: rgba(34,197,94,0.15); }

      .card h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #fff;
      }
      .card p {
        font-size: 0.92rem;
        color: var(--muted);
        line-height: 1.55;
      }

      /* ── How It Works ── */
      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        counter-reset: step;
      }
      .step {
        text-align: center;
        counter-increment: step;
      }
      .step::before {
        content: counter(step);
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(59,130,246,0.12);
        border: 2px solid rgba(59,130,246,0.3);
        color: #93c5fd;
        font-weight: 700;
        font-size: 1.1rem;
        margin: 0 auto 1rem;
      }
      .step h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }
      .step p {
        font-size: 0.9rem;
        color: var(--muted);
        max-width: 280px;
        margin: 0 auto;
      }

      /* ── Stats Row ── */
      .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        padding: 3rem 0;
      }
      .stat {
        text-align: center;
      }
      .stat-value {
        display: block;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        background: linear-gradient(135deg, var(--accent), var(--teal));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .stat-label {
        font-size: 0.85rem;
        color: var(--muted);
        margin-top: 0.25rem;
      }

      /* ── Requirements ── */
      .req-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }
      .req-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.75rem;
        text-align: center;
      }
      .req-card h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }
      .req-card p { font-size: 0.88rem; color: var(--muted); }

      /* ── Config Table ── */
      .config-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
      }
      .config-table th, .config-table td {
        text-align: left;
        padding: 0.85rem 1rem;
        border-bottom: 1px solid var(--border);
      }
      .config-table th {
        color: var(--muted);
        font-weight: 500;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .config-table td:first-child {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: #93c5fd;
      }
      .config-table td:last-child {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85rem;
        color: var(--muted);
      }

      /* ── CTA ── */
      .cta {
        text-align: center;
        padding: 5rem 0;
      }
      .cta h2 { margin-bottom: 1rem; }
      .cta p {
        color: var(--muted);
        margin-bottom: 2rem;
        font-size: 1.05rem;
      }

      /* ── Footer ── */
      footer {
        padding: 3rem 1.5rem;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--muted);
        font-size: 0.88rem;
      }
      footer a {
        color: var(--fg);
        font-weight: 600;
      }
      footer a:hover { color: var(--accent); text-decoration: none; }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .grid, .steps, .req-grid, .stats { grid-template-columns: 1fr; }
        .hero { padding: 4rem 1rem 3rem; }
        .install-card { padding: 1.5rem; }
        .nav-links { gap: 1rem; }
        section { padding: 3rem 0; }
      }

      @media (min-width: 769px) and (max-width: 1024px) {
        .grid { grid-template-columns: repeat(2, 1fr); }
        .stats { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/gobarrygo/" class="nav-brand">GoBarryGo</a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#install">Install</a>
        <a href="#configure">Configure</a>
        <a href={repoUrl} target="_blank">GitHub</a>
      </div>
    </nav>

    <div class="hero">
      <div class="hero-glow"></div>
      <div class="container">
        <span class="badge">v0.0.5 BHOODEVI &mdash; Open Source</span>
        <h1>Download manager that<br>stays out of your way</h1>
        <p class="hero-sub">
          GoBarryGo wraps aria2c in a native desktop shell built with Go and React&nbsp;19.
          No Electron. No bloat. Just fast, parallel downloads with a modern control surface.
        </p>
        <div class="actions">
          <a href={repoUrl + "/releases/latest"} class="btn btn-primary">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </a>
          <a href={repoUrl} class="btn btn-ghost" target="_blank">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 016.02 0c2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Star on GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="stats">
        <div class="stat">
          <span class="stat-value">&lt;30 MB</span>
          <span class="stat-label">RAM usage</span>
        </div>
        <div class="stat">
          <span class="stat-value">~15 MB</span>
          <span class="stat-label">Binary size</span>
        </div>
        <div class="stat">
          <span class="stat-value">3</span>
          <span class="stat-label">Platforms</span>
        </div>
        <div class="stat">
          <span class="stat-value">MIT</span>
          <span class="stat-label">License</span>
        </div>
      </div>
    </div>

    <div class="container">
      <section id="features">
        <span class="section-label">Features</span>
        <h2>Everything you need, nothing you don't</h2>
        <p class="section-desc">
          GoBarryGo focuses on being a thin, fast control layer over aria2c. Every feature is designed
          to be useful without adding weight.
        </p>
        <div class="grid">
          <div class="card">
            <div class="card-icon card-icon--blue">&#9889;</div>
            <h3>Parallel splitting</h3>
            <p>Leverage aria2c's multi-connection downloads. Configure split count and connections per server for maximum throughput.</p>
          </div>
          <div class="card">
            <div class="card-icon card-icon--teal">&#128268;</div>
            <h3>Auto-resume</h3>
            <p>Downloads survive crashes, reboots, and network drops. aria2c's session recovery picks up exactly where it left off.</p>
          </div>
          <div class="card">
            <div class="card-icon card-icon--amber">&#128737;</div>
            <h3>Real-time dashboard</h3>
            <p>Live speed, ETA, progress bars, and connection counts. Inspect individual files within multi-file downloads.</p>
          </div>
          <div class="card">
            <div class="card-icon card-icon--rose">&#128230;</div>
            <h3>Single binary</h3>
            <p>No installer required. AppImage on Linux, .app on macOS, portable .exe on Windows. Drop it anywhere and run.</p>
          </div>
          <div class="card">
            <div class="card-icon card-icon--violet">&#9881;</div>
            <h3>Full preferences</h3>
            <p>Tune concurrent downloads, split size, file allocation strategy, user-agent, and notification behavior from the UI.</p>
          </div>
          <div class="card">
            <div class="card-icon card-icon--green">&#128274;</div>
            <h3>Privacy first</h3>
            <p>Zero telemetry, zero tracking, zero cloud. Everything runs locally on your machine. Fully open source under MIT.</p>
          </div>
        </div>
      </section>

      <section>
        <span class="section-label">How It Works</span>
        <h2>Three steps to fast downloads</h2>
        <p class="section-desc">
          GoBarryGo manages an embedded aria2c process via JSON-RPC, so you get a native GUI without learning command-line flags.
        </p>
        <div class="steps">
          <div class="step">
            <h3>Install</h3>
            <p>Download the release for your OS or run the one-line installer script.</p>
          </div>
          <div class="step">
            <h3>Point to aria2c</h3>
            <p>Open Preferences, pick your aria2c binary. GoBarryGo boots the RPC server automatically.</p>
          </div>
          <div class="step">
            <h3>Paste & go</h3>
            <p>Hit "Add download", paste URLs, and watch parallel splits fill your progress bars.</p>
          </div>
        </div>
      </section>

      <section id="install">
        <span class="section-label">Installation</span>
        <h2>Get started in seconds</h2>
        <p class="section-desc">
          Choose the method that fits your workflow. All downloads are checksummed in every release.
        </p>
        <div class="install-card">
          <div class="install-tabs">
            <span class="tab tab--active">Linux / macOS / Git Bash</span>
            <span class="tab">Manual download</span>
          </div>
          <div class="code-block">
            <span class="comment"># One-line universal installer</span><br>
            <span class="prompt">$</span> <span class="cmd">curl -fsSL {repoUrl}/raw/main/install.sh | bash</span>
          </div>
          <p class="install-note">
            The script auto-detects your OS and architecture, downloads the latest release, and places the
            binary on your PATH. For manual installation, grab the appropriate archive from
            <a href={repoUrl + "/releases/latest"}>GitHub Releases</a> and extract it anywhere you like.
          </p>
          <h3 style="margin-top: 2rem; font-size: 1rem; margin-bottom: 0.75rem;">Package formats</h3>
          <div class="grid" style="gap: 0.75rem;">
            <div class="req-card">
              <h3>Linux</h3>
              <p>AppImage, .deb, .rpm</p>
            </div>
            <div class="req-card">
              <h3>macOS</h3>
              <p>.app bundle (ZIP)</p>
            </div>
            <div class="req-card">
              <h3>Windows</h3>
              <p>NSIS installer, portable .exe</p>
            </div>
          </div>
        </div>
      </section>

      <section id="configure">
        <span class="section-label">Configuration</span>
        <h2>Tune it to your network</h2>
        <p class="section-desc">
          All settings are accessible from the in-app Preferences dialog. Your config is stored as a
          JSON file you can back up or share.
        </p>
        <div class="install-card">
          <table class="config-table">
            <thead>
              <tr>
                <th>Setting</th>
                <th>Description</th>
                <th>Default</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>concurrent</td>
                <td>Max parallel downloads</td>
                <td>4</td>
              </tr>
              <tr>
                <td>split</td>
                <td>Segments per file</td>
                <td>8</td>
              </tr>
              <tr>
                <td>connections</td>
                <td>Connections per server</td>
                <td>8</td>
              </tr>
              <tr>
                <td>min-split-size</td>
                <td>Minimum segment size</td>
                <td>4M</td>
              </tr>
              <tr>
                <td>file-allocation</td>
                <td>Prealloc, falloc, trunc, none</td>
                <td>prealloc</td>
              </tr>
              <tr>
                <td>continue</td>
                <td>Resume partial downloads</td>
                <td>true</td>
              </tr>
              <tr>
                <td style="border-bottom: none;">auto-rename</td>
                <td style="border-bottom: none;">Rename on filename conflicts</td>
                <td style="border-bottom: none;">true</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section>
        <span class="section-label">Requirements</span>
        <h2>What you need</h2>
        <p class="section-desc">
          GoBarryGo itself is self-contained. The only external dependency is aria2c.
        </p>
        <div class="req-grid">
          <div class="req-card">
            <h3>aria2c</h3>
            <p>Any recent version. GoBarryGo manages the process lifecycle for you.</p>
          </div>
          <div class="req-card">
            <h3>OS</h3>
            <p>Linux (GTK&nbsp;3), macOS&nbsp;10.15+, Windows&nbsp;10+</p>
          </div>
          <div class="req-card">
            <h3>Disk</h3>
            <p>~15&nbsp;MB for the binary. No runtime frameworks needed.</p>
          </div>
        </div>
      </section>

      <section class="cta">
        <h2>Ready to ditch the bloat?</h2>
        <p>GoBarryGo is free, open source, and built for people who care about performance.</p>
        <div class="actions">
