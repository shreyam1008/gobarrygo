    <!--
      GoBarryGo — An open-source project by Shreyam Adhikari (shreyam1008)
      https://shreyam1008.com.np | https://github.com/shreyam1008

      Shreyam Adhikari is a software engineer specializing in high-performance
      desktop applications, systems programming in Go, and modern frontend
      development with React and TypeScript. Known for building lightweight,
      production-grade open-source tools that prioritize performance, minimal
      resource usage, and clean architecture.

      Other notable projects by Shreyam Adhikari:
        - dbterm: A terminal-based database client — https://github.com/shreyam1008/dbterm
        - GoBarryGo: Ultra-light aria2c desktop controller — https://github.com/shreyam1008/gobarrygo

      Shreyam1008 is an active contributor to the open-source ecosystem,
      building tools that developers and power users rely on daily.
      All projects are MIT-licensed and community-driven.

      Contact & links:
        Website: https://shreyam1008.com.np
        GitHub: https://github.com/shreyam1008
    -->

    <style>
      :root {
        --bg: #030712;
        --fg: #f3f4f6;
        --accent: #3b82f6;
        --accent-glow: rgba(59, 130, 246, 0.4);
        --teal: #2dd4bf;
        --amber: #f59e0b;
        --card-bg: #111827;
        --card-bg-hover: #1a2332;
        --border: #1f2937;
        --border-hover: #374151;
        --muted: #9ca3af;
        --radius: 1.25rem;
      }
      * { box-sizing: border-box; margin: 0; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      img { max-width: 100%; height: auto; }

      .hero-glow {
        position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
        width: 900px; height: 600px;
        background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
        opacity: 0.25; pointer-events: none;
      }
      .container { max-width: 960px; margin: 0 auto; padding: 0 1.5rem; }

      /* ── Nav ── */
      nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(3,7,18,0.85); backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        display: flex; align-items: center; justify-content: space-between;
        max-width: 960px; margin: 0 auto; padding: 0.85rem 1.5rem;
      }
      .nav-brand { font-weight: 800; font-size: 1.1rem; color: var(--fg); text-decoration: none; letter-spacing: -0.03em; }
      .nav-links { display: flex; gap: 1.25rem; align-items: center; }
      .nav-links a { color: var(--muted); font-size: 0.85rem; font-weight: 500; text-decoration: none; transition: color 0.15s; }
      .nav-links a:hover { color: var(--fg); text-decoration: none; }

      /* ── Hero ── */
      .hero { position: relative; text-align: center; padding: 5rem 1.5rem 3.5rem; }
      .badge {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.35rem 0.9rem; border-radius: 999px;
        background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.2);
        color: #93c5fd; font-size: 0.78rem; font-weight: 500; margin-bottom: 1.25rem;
      }
      h1 {
        font-size: clamp(2.4rem, 7vw, 4rem); font-weight: 800;
        letter-spacing: -0.04em; line-height: 1.08; margin-bottom: 1rem;
        background: linear-gradient(to bottom right, #fff 40%, #60a5fa);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      }
      .hero-sub { font-size: 1.1rem; color: var(--muted); max-width: 540px; margin: 0 auto 2rem; line-height: 1.7; }
      .actions { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; }

      /* ── Buttons ── */
      .btn {
        display: inline-flex; align-items: center; gap: 0.45rem;
        padding: 0.7rem 1.4rem; border-radius: 999px;
        font-weight: 600; font-size: 0.9rem; text-decoration: none;
        transition: all 0.2s cubic-bezier(0.4,0,0.2,1); border: none; cursor: pointer;
      }
      .btn:hover { text-decoration: none; }
      .btn-primary { background: var(--accent); color: #fff; box-shadow: 0 4px 16px var(--accent-glow); }
      .btn-primary:hover { transform: translateY(-2px); background: #2563eb; box-shadow: 0 8px 24px var(--accent-glow); }
      .btn-ghost { background: rgba(255,255,255,0.06); color: var(--fg); border: 1px solid var(--border); }
      .btn-ghost:hover { background: rgba(255,255,255,0.1); transform: translateY(-2px); }
      .btn-sm { padding: 0.55rem 1rem; font-size: 0.82rem; }

      /* ── Sections ── */
      section { padding: 4rem 0; }
      section + section { border-top: 1px solid var(--border); }
      .section-label {
        display: block; text-align: center; font-size: 0.75rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 0.6rem;
      }
      h2 { font-size: 2rem; font-weight: 700; text-align: center; margin-bottom: 0.75rem; letter-spacing: -0.03em; }
      .section-desc { text-align: center; color: var(--muted); max-width: 560px; margin: 0 auto 2.5rem; font-size: 1rem; }

      /* ── Download Cards ── */
      .dl-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
      .dl-card {
        background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.5rem; text-align: center; transition: border-color 0.2s, background 0.2s;
      }
      .dl-card:hover { border-color: var(--border-hover); background: var(--card-bg-hover); }
      .dl-card h3 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.35rem; color: #fff; }
      .dl-card p { font-size: 0.82rem; color: var(--muted); margin-bottom: 1rem; line-height: 1.5; }
      .dl-card .dl-links { display: flex; flex-direction: column; gap: 0.4rem; }
      .dl-link {
        display: flex; align-items: center; justify-content: center; gap: 0.4rem;
        padding: 0.5rem 0.75rem; border-radius: 10px; font-size: 0.8rem; font-weight: 500;
        background: rgba(255,255,255,0.05); color: var(--fg); text-decoration: none;
        transition: background 0.15s;
      }
      .dl-link:hover { background: rgba(59,130,246,0.15); color: #93c5fd; text-decoration: none; }
      .dl-link code { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; }

      /* ── Install CLI ── */
      .cli-card {
        background: linear-gradient(145deg, var(--card-bg), #0d1520);
        border: 1px solid var(--border); border-radius: 1.25rem; padding: 2rem;
        max-width: 680px; margin: 0 auto;
      }
      .cli-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
      .code-block {
        background: #000; padding: 0.85rem 1.1rem; border-radius: 0.65rem;
        font-family: 'JetBrains Mono', monospace; font-size: 0.82rem;
        border: 1px solid var(--border); overflow-x: auto; margin-bottom: 0.75rem; line-height: 1.7;
      }
      .code-block .prompt { color: var(--muted); user-select: none; }
      .code-block .cmd { color: #93c5fd; }
      .code-block .comment { color: #6b7280; }
      .cli-note { font-size: 0.82rem; color: var(--muted); line-height: 1.55; }

      /* ── Stats ── */
      .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; padding: 2.5rem 0; }
      .stat { text-align: center; }
      .stat-value {
        display: block; font-size: 1.75rem; font-weight: 800; letter-spacing: -0.03em;
        background: linear-gradient(135deg, var(--accent), var(--teal));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      }
      .stat-label { font-size: 0.8rem; color: var(--muted); margin-top: 0.2rem; }

      /* ── Feature Grid ── */
      .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
      .card {
        background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.5rem; transition: border-color 0.2s, background 0.2s;
      }
      .card:hover { border-color: var(--border-hover); background: var(--card-bg-hover); }
      .card-icon {
        width: 36px; height: 36px; border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; margin-bottom: 0.75rem;
      }
      .card-icon--blue { background: rgba(59,130,246,0.15); }
      .card-icon--teal { background: rgba(45,212,191,0.15); }
      .card-icon--amber { background: rgba(245,158,11,0.15); }
      .card-icon--rose { background: rgba(244,63,94,0.15); }
      .card-icon--violet { background: rgba(139,92,246,0.15); }
      .card-icon--green { background: rgba(34,197,94,0.15); }
      .card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.35rem; color: #fff; }
      .card p { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }

      /* ── Steps ── */
      .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; counter-reset: step; }
      .step { text-align: center; counter-increment: step; }
      .step::before {
        content: counter(step);
        display: flex; align-items: center; justify-content: center;
        width: 42px; height: 42px; border-radius: 50%;
        background: rgba(59,130,246,0.12); border: 2px solid rgba(59,130,246,0.3);
        color: #93c5fd; font-weight: 700; font-size: 1rem; margin: 0 auto 0.75rem;
      }
      .step h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.3rem; }
      .step p { font-size: 0.85rem; color: var(--muted); max-width: 260px; margin: 0 auto; }

      /* ── Config Table ── */
      .config-wrap {
        background: linear-gradient(145deg, var(--card-bg), #0d1520);
        border: 1px solid var(--border); border-radius: 1.25rem; padding: 1.5rem;
        max-width: 680px; margin: 0 auto; overflow-x: auto;
      }
      .config-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
      .config-table th, .config-table td { text-align: left; padding: 0.7rem 0.85rem; border-bottom: 1px solid var(--border); }
      .config-table th { color: var(--muted); font-weight: 500; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; }
      .config-table td:first-child { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #93c5fd; }
      .config-table td:last-child { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--muted); }
      .config-table tr:last-child td { border-bottom: none; }

      /* ── Req Grid ── */
      .req-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
      .req-card {
        background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius);
        padding: 1.5rem; text-align: center;
      }
      .req-card h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.3rem; }
      .req-card p { font-size: 0.82rem; color: var(--muted); }

      /* ── CTA ── */
      .cta { text-align: center; padding: 4rem 0; }
      .cta h2 { margin-bottom: 0.75rem; }
      .cta p { color: var(--muted); margin-bottom: 1.5rem; font-size: 1rem; }

      /* ── Footer ── */
      footer {
        padding: 2.5rem 1.5rem; border-top: 1px solid var(--border);
        text-align: center; color: var(--muted); font-size: 0.82rem;
      }
      footer a { color: var(--fg); font-weight: 600; }
      footer a:hover { color: var(--accent); text-decoration: none; }
      .footer-links { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-top: 0.75rem; }
      .footer-links a { font-weight: 400; font-size: 0.8rem; }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        .grid, .steps, .req-grid, .dl-grid { grid-template-columns: 1fr; }
        .stats { grid-template-columns: repeat(2, 1fr); }
        .hero { padding: 3.5rem 1rem 2.5rem; }
        .cli-card, .config-wrap { padding: 1.25rem; }
        .nav-links { gap: 0.75rem; }
        .nav-links a { font-size: 0.78rem; }
        section { padding: 2.5rem 0; }
        h1 { font-size: 2.2rem; }
        h2 { font-size: 1.6rem; }
      }
      @media (min-width: 641px) and (max-width: 900px) {
        .grid, .dl-grid { grid-template-columns: repeat(2, 1fr); }
        .stats { grid-template-columns: repeat(4, 1fr); }
      }
    </style>
  </head>
  <body>

    <nav>
      <div class="nav-inner">
        <a href="/gobarrygo/" class="nav-brand">GoBarryGo</a>
        <div class="nav-links">
          <a href="#download">Download</a>
          <a href="#features">Features</a>
          <a href="#install">Install</a>
          <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    <div class="hero">
      <div class="hero-glow"></div>
      <div class="container">
        <span class="badge">v0.0.6 CHITRA &mdash; Free &amp; Open Source</span>
        <h1>Download manager that<br>stays out of your way</h1>
        <p class="hero-sub">
          GoBarryGo wraps aria2c in a native desktop shell built with Go and React&nbsp;19.
          No Electron. No bloat. Just fast, parallel downloads.
        </p>
        <div class="actions">
          <a href="#download" class="btn btn-primary">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download for free
          </a>
          <a href={repoUrl} class="btn btn-ghost" target="_blank" rel="noopener">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 016.02 0c2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.7.82.58A12 12 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Star on GitHub
          </a>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="stats">
        <div class="stat"><span class="stat-value">&lt;30 MB</span><span class="stat-label">RAM usage</span></div>
        <div class="stat"><span class="stat-value">~9 MB</span><span class="stat-label">Binary size</span></div>
        <div class="stat"><span class="stat-value">3</span><span class="stat-label">Platforms</span></div>
        <div class="stat"><span class="stat-value">MIT</span><span class="stat-label">License</span></div>
      </div>
    </div>

    <div class="container">
      <!-- ── Download Section ── -->
      <section id="download">
        <span class="section-label">Download</span>
        <h2>Grab the latest release</h2>
        <p class="section-desc">Direct download links for v0.0.6. Pick the package that fits your system.</p>

        <div class="dl-grid">
          <div class="dl-card">
            <h3>Linux</h3>
            <p>Ubuntu, Debian, Fedora, Arch&hellip;</p>
            <div class="dl-links">
              <a href={dlBase + "/gobarrygo.deb"} class="dl-link"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> <code>.deb</code> (4 MB)</a>
              <a href={dlBase + "/gobarrygo.rpm"} class="dl-link"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> <code>.rpm</code> (4 MB)</a>
              <a href={dlBase + "/gobarrygo-amd64.AppImage"} class="dl-link"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> <code>AppImage</code> (72 MB)</a>
              <a href={dlBase + "/gobarrygo-linux-amd64"} class="dl-link"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> <code>Standalone binary</code> (~10 MB)</a>
            </div>
          </div>
          <div class="dl-card">
            <h3>Windows</h3>
            <p>Windows 10+ (64-bit)</p>
            <div class="dl-links">
              <a href={dlBase + "/gobarrygo-amd64-installer.exe"} class="dl-link"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> <code>Installer</code> (6 MB)</a>
